# =============================================================================
# Adapto Digital TV Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# General Settings
# =============================================================================
NODE_ENV=production
DEBUG=0
LOG_LEVEL=WARN

# =============================================================================
# Database Configuration
# =============================================================================
# For Docker use service names: postgres, redis
# For local development use: localhost
DATABASE_URL=postgresql://adapto:changeme@postgres:5432/adapto
POSTGRES_DB=adapto
POSTGRES_USER=adapto
POSTGRES_PASSWORD=changeme

# Express.js backend (optional overrides)
API_BACKEND_UPSTREAM=back-express:8001
EXPRESS_PORT=8001
EXPRESS_DB_SSL=
EXPRESS_DB_POOL_SIZE=10
EXPRESS_DB_IDLE_TIMEOUT=30000
CORS_ORIGIN=https://example.com
# Express media serving
MEDIA_ROOT=/app/media
MEDIA_URL_PREFIX=/api/v1/media
# EXPRESS_DATABASE_URL=postgresql://adapto:changeme@postgres:5432/adapto

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Django Backend Settings
# =============================================================================
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,api.localhost,example.com,dash.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://tv.localhost,https://example.com
# CSRF и безопасность
CSRF_TRUSTED_ORIGINS=https://example.com,https://dash.example.com
USE_TLS=1

# Admin User Settings (автоматическое создание суперпользователя)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# =============================================================================
# Frontend Settings
# =============================================================================
# All environments use the same production API
NEXT_PUBLIC_API_URL=https://dash.example.com/api/v1
NEXT_PUBLIC_WS_URL=wss://dash.example.com/ws
NEXT_PUBLIC_DEBUG=0

# =============================================================================
# SmartTV Settings
# =============================================================================
REACT_APP_API_BASE_URL=https://dash.example.com/api/v1
REACT_APP_WS_URL=wss://dash.example.com/ws
REACT_APP_DEBUG=0

# =============================================================================
# Mobile App Settings
# =============================================================================
EXPO_PUBLIC_API_BASE_URL=https://dash.example.com/api/v1
EXPO_PUBLIC_WS_URL=wss://dash.example.com/ws
EXPO_PUBLIC_DEBUG=0
EXPO_USE_LOCAL_CLI=1
EXPO_DEVTOOLS_LISTEN_ADDRESS=0.0.0.0

# =============================================================================
# External Services
# =============================================================================

# MediaMTX Streaming Server
MEDIAMTX_WEBRTC_HOSTS=localhost,127.0.0.1,example.com

# SeaweedFS Object Storage (S3-compatible)
SEAWEEDFS_S3_ACCESS_KEY=your-access-key
SEAWEEDFS_S3_SECRET_KEY=your-secret-key
SEAWEEDFS_S3_ENDPOINT=http://localhost:8333
SEAWEEDFS_S3_REGION=us-east-1
SEAWEEDFS_S3_BUCKET=adapto-media

# OpenAI API (for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# Email Settings (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Adapto Digital TV <noreply@example.com>

# File Storage (AWS S3 or similar)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=adapto-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.example.com

# =============================================================================
# Security Settings
# =============================================================================

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRATION_TIME=3600

# API Rate Limiting
API_RATE_LIMIT=100/hour
WEB_RATE_LIMIT=1000/hour

# =============================================================================
# Monitoring & Analytics
# =============================================================================

# Sentry (Error tracking)
SENTRY_DSN=your-sentry-dsn-here

# Google Analytics
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# =============================================================================
# Development Tools
# =============================================================================

# MailHog (Development email testing)
MAILHOG_HOST=localhost
MAILHOG_PORT=1025

# =============================================================================
# Production Settings (Override in production)
# =============================================================================

# Domain Settings
DOMAIN=example.com
API_DOMAIN=api.example.com
TV_DOMAIN=tv.example.com

# SSL Settings
SSL_CERT_PATH=/etc/ssl/certs/server.crt
SSL_KEY_PATH=/etc/ssl/private/server.key

# CDN Settings
CDN_URL=https://cdn.example.com

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Cache Settings
CACHE_TTL=3600
CACHE_MAX_ENTRIES=10000
