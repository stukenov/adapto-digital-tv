# Django Backend Configuration
DEBUG=0
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://user:password@postgres:5432/adapto
ALLOWED_HOSTS=example.com,dash.example.com,localhost

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://example.com/api/v1
NEXT_PUBLIC_WS_URL=wss://dash.example.com/ws
NEXT_PUBLIC_DEBUG=0
NEXT_PUBLIC_GA_ID=

# Backend Switcher
# USE_EXPRESS_BACKEND=true  - использовать Express.js бэкенд (легковесный, без ORM)
# USE_EXPRESS_BACKEND=false - использовать Django бэкенд (с админкой)
USE_EXPRESS_BACKEND=true

# PostgreSQL
POSTGRES_DB=adapto
POSTGRES_USER=adapto
POSTGRES_PASSWORD=your-password-here

# MediaMTX
TZ=Asia/Almaty
MEDIAMTX_WEBRTC_HOSTS=example.com

# Logging
LOG_LEVEL=WARN
