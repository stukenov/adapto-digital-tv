{
  "name": "adapto-tv",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Universal Smart TV React App for Samsung Tizen, LG webOS, Android TV, Apple tvOS, Roku and Web PWA",
  "author": "Adapto Digital TV Development Team",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/adapto-digital-tv/adapto.git",
    "directory": "apps/smarttv"
  },
  "keywords": [
    "smart-tv",
    "tizen",
    "webos",
    "android-tv",
    "tvos",
    "roku",
    "pwa",
    "react",
    "typescript",
    "hls"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn dev:web",
    "dev:web": "yarn workspace adapto-renderer-web dev",
    "dev:core": "yarn workspace adapto-app-core build --watch",
    "dev:android-tv": "yarn workspace adapto-renderer-rn-tv android",
    "dev:tvos": "yarn workspace adapto-renderer-rn-tv ios",
    "build": "yarn build:core && yarn build:pwa",
    "build:core": "yarn workspace adapto-app-core build",
    "build:pwa": "yarn workspace adapto-renderer-web build:pwa",
    "build:tizen": "yarn build:core && yarn workspace adapto-renderer-web build:tizen",
    "build:webos": "yarn build:core && yarn workspace adapto-renderer-web build:webos",
    "build:android-tv": "node scripts/build-android-tv.js",
    "build:tvos": "node scripts/build-tvos.js",
    "build:all": "yarn build:core && concurrently \"yarn build:pwa\" \"yarn build:tizen\" \"yarn build:webos\" \"yarn build:android-tv\" \"yarn build:tvos\"",
    "preview": "yarn workspace adapto-renderer-web preview",
    "clean": "yarn workspaces run clean && rm -rf node_modules/.cache",
    "clean:dist": "find packages -name 'dist' -type d -exec rm -rf {} +",
    "clean:deps": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "reset": "yarn clean:deps && yarn install",
    "lint": "eslint packages --ext .ts,.tsx,.js,.jsx --max-warnings 0 --ignore-pattern '**/dist/**' --ignore-pattern '**/build/**' --ignore-pattern '**/node_modules/**'",
    "lint:fix": "eslint packages --ext .ts,.tsx,.js,.jsx --fix --ignore-pattern '**/dist/**' --ignore-pattern '**/build/**' --ignore-pattern '**/node_modules/**'",
    "test": "yarn workspace adapto-app-core test",
    "test:all": "yarn workspaces run test",
    "test:watch": "yarn workspace adapto-app-core test --watch",
    "test:coverage": "yarn workspace adapto-app-core test --coverage",
    "typecheck": "yarn workspaces run typecheck",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,md}\"",
    "deps:check": "yarn outdated",
    "deps:update": "yarn upgrade-interactive --latest",
    "docs": "echo 'Opening design system documentation...' && open packages/app-core/DESIGN_SYSTEM.md",
    "migration": "echo 'Opening migration guide...' && open MIGRATION_GUIDE.md"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/plugin-proposal-class-properties": "^7.18.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.0",
    "@babel/plugin-transform-runtime": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.23.0",
    "@eslint/js": "^9.31.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^29.0.0",
    "babel-plugin-styled-components": "^2.1.0",
    "concurrently": "^8.2.0",
    "core-js": "^3.33.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-transform-stub": "^2.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "packageManager": "yarn@3.6.0",
  "resolutions": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "ip": "npm:@leichtgewicht/ip-codec@^2.0.5",
    "esbuild": "^0.25.0",
    "vite": "^7.0.0",
    "on-headers": "^1.1.0",
    "@eslint/plugin-kit": "^0.3.4"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-is": "^18.2.0",
    "react-router-dom": "^7.7.1",
    "styled-components": "^6.1.1"
  }
}
